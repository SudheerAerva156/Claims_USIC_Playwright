{
  "name": "playwright-claims-framework",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "ts-node scripts/clean-reports.ts",
    "pretest": "npm run clean",
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke --grep @smoke",
    "test:upgrade:base-capability": "playwright test tests/upgrade/base-capability --grep @baseCapability",
    "test:upgrade:base-defects": "playwright test tests/upgrade/base-defects --grep @baseDefect",
    "test:regression": "ts-node tests/regression/regression-runner.ts",
    "test:regression:recent-tickets": "playwright test tests/regression-cases/recent-tickets --grep @recentTickets",
    "test:regression:cr": "playwright test tests/regression-cases/change-requests --grep @cr",
    "test:regression:incidents": "playwright test tests/regression-cases/incidents --grep @incident",
    "test:regression:high-priority-defects": "playwright test tests/regression-cases/high-priority-defects --grep @highPriorityDefect",
    "test:regression:reused-upgrade": "playwright test tests/regression-cases/reused-upgrade --grep @reusedUpgrade",
    "allure:generate": "allure generate ./allure-results --clean -o ./reports/allure-report",
    "allure:open": "allure open ./reports/allure-report",
    "report:dashboard": "ts-node scripts/generate-dashboard.ts",
    "clean:reports": "ts-node scripts/clean-reports.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.12",
    "allure-commandline": "^2.29.0",
    "allure-playwright": "^3.0.0-beta.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
